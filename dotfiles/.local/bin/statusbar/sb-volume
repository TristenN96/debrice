#!/bin/sh

# Prints the current volume ("Vol 40%") or "Muted".
# Alternative using amixer:
# amixer get Master | grep '%' | head -n 1 | awk -F'[' '{print $2}' ...

if pactl get-sink-mute @DEFAULT_SINK@ | grep -q "yes"; then
	echo "Muted"
else
	volume=$(pactl list sinks | grep '^[[:space:]]Volume:' | head -n 1 |
		awk '{print $5}' | tr -d '%')
	echo "Vol $volume%"
fi
