#!/bin/sh

# Prints all batteries, their percentage remaining and a label corresponding
# to charge status (Chg for charging, Bat for discharging, etc.).

case $BLOCK_BUTTON in
	3) notify-send "Battery module" "Bat: discharging
Idle: not charging
Full: fully charged
Chg: charging
!: battery very low!
- Scroll to change adjust xbacklight." ;;
	4) xbacklight -inc 10 ;;
	5) xbacklight -dec 10 ;;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

# Loop through all attached batteries and format the info
for battery in /sys/class/power_supply/BAT?*; do
	# If non-first battery, print a space separator.
	[ -n "${capacity+x}" ] && printf " "
	# Sets up the status and capacity
	case "$(cat "$battery/status" 2>&1)" in
		"Full") status="Full" ;;
		"Discharging") status="Bat" ;;
		"Charging") status="Chg" ;;
		"Not charging") status="Idle" ;;
		"Unknown") status="Bat" ;;
		*) exit 1 ;;
	esac
	capacity="$(cat "$battery/capacity" 2>&1)"
	# Will make a warn variable if discharging and low
	[ "$status" = "Bat" ] && [ "$capacity" -le 25 ] && warn="!"
	# Prints the info
	printf "%s %d%%%s" "$status" "$capacity" "$warn"; unset warn
done && printf "\\n"
