#!/bin/sh

# Show wifi strength, ethernet state, and VPN state as plain text.

case $BLOCK_BUTTON in
	1) "$TERMINAL" -e nmtui ;;
	3) notify-send "Internet module" "\- Click to connect
WiFi off: wifi disabled
WiFi down: no wifi connection
WiFi N%: wifi connection with quality
Eth off: no ethernet
Eth: ethernet working
VPN: a vpn connection is active
" ;;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

# Wifi
if [ "$(cat /sys/class/net/w*/operstate 2>/dev/null)" = 'up' ] ; then
	wifiicon="$(awk '/^\s*w/ { print "WiFi", int($3 * 100 / 70) "% " }' /proc/net/wireless)"
elif [ "$(cat /sys/class/net/w*/operstate 2>/dev/null)" = 'down' ] ; then
	[ "$(cat /sys/class/net/w*/flags 2>/dev/null)" = '0x1003' ] && wifiicon="WiFi down " || wifiicon="WiFi off "
fi

# Ethernet
[ "$(cat /sys/class/net/e*/operstate 2>/dev/null)" = 'up' ] && ethericon="Eth" || ethericon="Eth off"

# TUN
[ -n "$(cat /sys/class/net/tun*/operstate 2>/dev/null)" ] && tunicon=" VPN"

printf "%s%s%s\n" "$wifiicon" "$ethericon" "$tunicon"
